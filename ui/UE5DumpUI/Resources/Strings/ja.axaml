<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Toolbar -->
    <sys:String x:Key="str.Connect">接続</sys:String>
    <sys:String x:Key="str.Disconnect">切断</sys:String>
    <sys:String x:Key="str.Language">言語</sys:String>

    <!-- Status -->
    <sys:String x:Key="str.Status.Connected">接続済み</sys:String>
    <sys:String x:Key="str.Status.Disconnected">未接続</sys:String>
    <sys:String x:Key="str.Status.Connecting">接続中...</sys:String>
    <sys:String x:Key="str.Status.Error">接続エラー</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="str.Tab.ClassStruct">クラス構造</sys:String>
    <sys:String x:Key="str.Tab.Pointers">グローバルポインタ</sys:String>
    <sys:String x:Key="str.Tab.HexView">Hex ビュー</sys:String>
    <sys:String x:Key="str.Tab.LiveWalker">ライブウォーカー</sys:String>
    <sys:String x:Key="str.Tab.InstanceFinder">インスタンス検索</sys:String>

    <!-- Object Tree -->
    <sys:String x:Key="str.ObjectTree.Title">オブジェクトツリー</sys:String>
    <sys:String x:Key="str.ObjectTree.Search">オブジェクト検索...</sys:String>
    <sys:String x:Key="str.ObjectTree.Load">読み込み</sys:String>
    <sys:String x:Key="str.ObjectTree.Loading">読み込み中...</sys:String>
    <sys:String x:Key="str.ObjectTree.Count">オブジェクト数: {0}</sys:String>

    <!-- Class Structure -->
    <sys:String x:Key="str.ClassStruct.Name">名前</sys:String>
    <sys:String x:Key="str.ClassStruct.Type">型</sys:String>
    <sys:String x:Key="str.ClassStruct.Offset">オフセット</sys:String>
    <sys:String x:Key="str.ClassStruct.Size">サイズ</sys:String>
    <sys:String x:Key="str.ClassStruct.Super">親クラス</sys:String>
    <sys:String x:Key="str.ClassStruct.PropsSize">プロパティサイズ</sys:String>
    <sys:String x:Key="str.ClassStruct.NoClass">オブジェクトを選択してクラス構造を表示</sys:String>

    <!-- Live Walker -->
    <sys:String x:Key="str.LiveWalker.StartWorld">GWorld から開始</sys:String>
    <sys:String x:Key="str.LiveWalker.Back">戻る</sys:String>
    <sys:String x:Key="str.LiveWalker.Refresh">更新</sys:String>
    <sys:String x:Key="str.LiveWalker.AddressHint">アドレス (0x...)</sys:String>
    <sys:String x:Key="str.LiveWalker.Go">移動</sys:String>
    <sys:String x:Key="str.LiveWalker.ExportCE">CE XML エクスポート</sys:String>
    <sys:String x:Key="str.LiveWalker.Value">値</sys:String>

    <!-- Instance Finder -->
    <sys:String x:Key="str.InstanceFinder.ClassNameHint">クラス名 (例: PlayerController)</sys:String>
    <sys:String x:Key="str.InstanceFinder.Search">検索</sys:String>
    <sys:String x:Key="str.InstanceFinder.Address">アドレス</sys:String>
    <sys:String x:Key="str.InstanceFinder.OpenInWalker">ライブウォーカーで開く</sys:String>

    <!-- Pointer Panel -->
    <sys:String x:Key="str.Pointers.GObjects">GObjects アドレス</sys:String>
    <sys:String x:Key="str.Pointers.GNames">GNames アドレス</sys:String>
    <sys:String x:Key="str.Pointers.GWorld">GWorld アドレス</sys:String>
    <sys:String x:Key="str.Pointers.UEVersion">UE バージョン</sys:String>
    <sys:String x:Key="str.Pointers.TotalObjects">オブジェクト総数</sys:String>
    <sys:String x:Key="str.Pointers.Copy">コピー</sys:String>
    <sys:String x:Key="str.Pointers.NotConnected">未接続 — 接続してポインタを表示</sys:String>

    <!-- Hex View -->
    <sys:String x:Key="str.HexView.Address">アドレス (0x...)</sys:String>
    <sys:String x:Key="str.HexView.Size">サイズ</sys:String>
    <sys:String x:Key="str.HexView.Read">読み取り</sys:String>
    <sys:String x:Key="str.HexView.LiveWatch">ライブ監視</sys:String>
    <sys:String x:Key="str.HexView.Interval">間隔 (ms)</sys:String>

    <!-- Errors -->
    <sys:String x:Key="str.Error.Connection">パイプサーバーへの接続に失敗しました</sys:String>
    <sys:String x:Key="str.Error.ReadFailed">メモリ読み取りに失敗しました</sys:String>
    <sys:String x:Key="str.Error.AlreadyRunning">UE5 Dump UI は既に実行中です</sys:String>

</ResourceDictionary>
