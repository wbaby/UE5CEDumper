<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Toolbar -->
    <sys:String x:Key="str.Connect">連線</sys:String>
    <sys:String x:Key="str.Disconnect">斷線</sys:String>
    <sys:String x:Key="str.Language">語言</sys:String>

    <!-- Status -->
    <sys:String x:Key="str.Status.Connected">已連線</sys:String>
    <sys:String x:Key="str.Status.Disconnected">未連線</sys:String>
    <sys:String x:Key="str.Status.Connecting">連線中...</sys:String>
    <sys:String x:Key="str.Status.Error">連線錯誤</sys:String>

    <!-- Tabs -->
    <sys:String x:Key="str.Tab.ClassStruct">類別結構</sys:String>
    <sys:String x:Key="str.Tab.Pointers">全域指標</sys:String>
    <sys:String x:Key="str.Tab.HexView">Hex 檢視</sys:String>

    <!-- Object Tree -->
    <sys:String x:Key="str.ObjectTree.Title">物件樹</sys:String>
    <sys:String x:Key="str.ObjectTree.Search">搜尋物件...</sys:String>
    <sys:String x:Key="str.ObjectTree.Load">載入</sys:String>
    <sys:String x:Key="str.ObjectTree.Loading">載入中...</sys:String>
    <sys:String x:Key="str.ObjectTree.Count">物件數: {0}</sys:String>

    <!-- Class Structure -->
    <sys:String x:Key="str.ClassStruct.Name">名稱</sys:String>
    <sys:String x:Key="str.ClassStruct.Type">類型</sys:String>
    <sys:String x:Key="str.ClassStruct.Offset">偏移</sys:String>
    <sys:String x:Key="str.ClassStruct.Size">大小</sys:String>
    <sys:String x:Key="str.ClassStruct.Super">父類別</sys:String>
    <sys:String x:Key="str.ClassStruct.PropsSize">屬性總大小</sys:String>
    <sys:String x:Key="str.ClassStruct.NoClass">選取物件以檢視其類別結構</sys:String>

    <!-- Pointer Panel -->
    <sys:String x:Key="str.Pointers.GObjects">GObjects 位址</sys:String>
    <sys:String x:Key="str.Pointers.GNames">GNames 位址</sys:String>
    <sys:String x:Key="str.Pointers.UEVersion">UE 版本</sys:String>
    <sys:String x:Key="str.Pointers.TotalObjects">物件總數</sys:String>
    <sys:String x:Key="str.Pointers.Copy">複製</sys:String>
    <sys:String x:Key="str.Pointers.NotConnected">尚未連線 — 請先連線以檢視指標</sys:String>

    <!-- Hex View -->
    <sys:String x:Key="str.HexView.Address">位址 (0x...)</sys:String>
    <sys:String x:Key="str.HexView.Size">大小</sys:String>
    <sys:String x:Key="str.HexView.Read">讀取</sys:String>
    <sys:String x:Key="str.HexView.LiveWatch">即時監控</sys:String>
    <sys:String x:Key="str.HexView.Interval">間隔 (ms)</sys:String>

    <!-- Errors -->
    <sys:String x:Key="str.Error.Connection">連線至 Pipe 伺服器失敗</sys:String>
    <sys:String x:Key="str.Error.ReadFailed">記憶體讀取失敗</sys:String>
    <sys:String x:Key="str.Error.AlreadyRunning">UE5 Dump UI 已有另一個執行個體正在運行</sys:String>

</ResourceDictionary>
