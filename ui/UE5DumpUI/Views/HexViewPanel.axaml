<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UE5DumpUI.ViewModels"
             xmlns:models="using:UE5DumpUI.Models"
             x:Class="UE5DumpUI.Views.HexViewPanel"
             x:DataType="vm:HexViewViewModel">

  <DockPanel Margin="8">
    <!-- Row 1: Address + Size + Read -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
      <TextBox Watermark="{StaticResource str.HexView.Address}"
               Text="{Binding Address}" Width="200"/>
      <TextBox Watermark="{StaticResource str.HexView.Size}"
               Text="{Binding Size}" Width="80"/>
      <Button Content="{StaticResource str.HexView.Read}"
              Command="{Binding ReadCommand}"
              ToolTip.Tip="{StaticResource str.Tip.HexView.Read}"
              Padding="12,4"/>
    </StackPanel>

    <!-- Row 2: Live Watch controls -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
      <Button Content="{Binding WatchButtonText}"
              Command="{Binding ToggleWatchCommand}"
              Padding="12,4"
              ToolTip.Tip="Start or stop live memory watching"/>
      <TextBlock Text="{StaticResource str.HexView.Interval}"
                 Foreground="#888" VerticalAlignment="Center" FontSize="12"/>
      <TextBox Text="{Binding WatchInterval}" Width="80"
               IsEnabled="{Binding !IsWatching}"
               ToolTip.Tip="Watch interval in milliseconds"/>
      <!-- Watch status indicator -->
      <Border Background="#2A4A2A" CornerRadius="4" Padding="8,2"
              IsVisible="{Binding IsWatching}">
        <TextBlock Text="{Binding WatchStatusText}"
                   Foreground="#4EC9B0" VerticalAlignment="Center" FontSize="12"/>
      </Border>
      <TextBlock Text="{Binding WatchStatusText}"
                 Foreground="#888" VerticalAlignment="Center" FontSize="12"
                 IsVisible="{Binding !IsWatching}"/>
    </StackPanel>

    <!-- Error display -->
    <TextBlock DockPanel.Dock="Top"
               Text="{Binding ErrorMessage}"
               Foreground="#F44747" FontSize="12"
               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
               Margin="0,0,0,4"/>

    <!-- Hex dump -->
    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding HexRows}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:HexViewRow">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="{Binding Offset}"
                         Foreground="#569CD6" FontFamily="Consolas" FontSize="13"
                         Width="80"/>
              <TextBlock Text="{Binding HexPart}"
                         Foreground="#D4D4D4" FontFamily="Consolas" FontSize="13"
                         Width="380"/>
              <TextBlock Text="{Binding AsciiPart}"
                         Foreground="#6A9955" FontFamily="Consolas" FontSize="13"/>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
