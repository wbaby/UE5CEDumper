<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UE5DumpUI.ViewModels"
             xmlns:m="using:UE5DumpUI.Models"
             x:Class="UE5DumpUI.Views.LiveWalkerPanel"
             x:DataType="vm:LiveWalkerViewModel">

  <DockPanel Margin="8">
    <!-- Top toolbar row 1: Navigation -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
      <Button Content="{StaticResource str.LiveWalker.StartWorld}"
              Command="{Binding StartFromWorldCommand}"
              ToolTip.Tip="{StaticResource str.Tip.LiveWalker.StartWorld}"
              Classes="accent" Padding="12,4"/>
      <Button Content="{StaticResource str.LiveWalker.Back}"
              Command="{Binding GoBackCommand}"
              ToolTip.Tip="{StaticResource str.Tip.LiveWalker.Back}"
              Padding="8,4"/>
      <Button Content="{StaticResource str.LiveWalker.Parent}"
              Command="{Binding GoToParentCommand}"
              IsVisible="{Binding HasParent}"
              Padding="8,4"
              Foreground="#C586C0"
              ToolTip.Tip="Navigate to parent (OuterPrivate)"/>
      <Button Content="{StaticResource str.LiveWalker.Refresh}"
              Command="{Binding RefreshCommand}"
              ToolTip.Tip="{StaticResource str.Tip.LiveWalker.Refresh}"
              Padding="8,4"/>
      <!-- Auto-refresh toggle + interval -->
      <ToggleButton Content="{StaticResource str.LiveWalker.AutoRefresh}"
                    IsChecked="{Binding IsAutoRefreshing}"
                    IsVisible="{Binding HasData}"
                    Padding="8,4"
                    ToolTip.Tip="Toggle automatic refresh"/>
      <NumericUpDown Value="{Binding AutoRefreshIntervalSec}"
                     Minimum="{Binding AutoRefreshMinSec}"
                     Maximum="60" Increment="1"
                     IsVisible="{Binding HasData}"
                     Width="140" Padding="4,2" FontSize="12"
                     Foreground="#D4D4D4"
                     FormatString="0"
                     ShowButtonSpinner="True"
                     ToolTip.Tip="Auto-refresh interval (seconds)"/>
      <TextBlock Text="{Binding AutoRefreshStatusText}"
                 Foreground="#888" VerticalAlignment="Center" FontSize="11"
                 IsVisible="{Binding HasData}"/>

      <!-- Bookmark controls (inline, after auto-refresh) -->
      <Border BorderBrush="#444" BorderThickness="1,0,0,0" Margin="8,0,0,0" Padding="8,0,0,0"
              IsVisible="{Binding HasData}">
        <StackPanel Orientation="Horizontal" Spacing="4">
          <!-- Save bookmark toggle (★) — yellow when active, grey when idle -->
          <Panel>
            <Button Content="{StaticResource str.LiveWalker.BookmarkSave}"
                    Command="{Binding ToggleBookmarkSaveModeCommand}"
                    ToolTip.Tip="{StaticResource str.Tip.LiveWalker.BookmarkSave}"
                    Padding="6,4" FontSize="13" MinWidth="28"
                    Cursor="Hand" Background="Transparent" BorderThickness="0"
                    Foreground="#888"
                    IsVisible="{Binding !IsBookmarkSaveMode}"/>
            <Button Content="{StaticResource str.LiveWalker.BookmarkSave}"
                    Command="{Binding ToggleBookmarkSaveModeCommand}"
                    ToolTip.Tip="{StaticResource str.Tip.LiveWalker.BookmarkSaveActive}"
                    Padding="6,4" FontSize="13" MinWidth="28"
                    Cursor="Hand" Background="Transparent" BorderThickness="0"
                    Foreground="#DCDCAA"
                    IsVisible="{Binding IsBookmarkSaveMode}"/>
          </Panel>
          <!-- Bookmark slots -->
          <ItemsControl ItemsSource="{Binding BookmarkSlots}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="2"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:BookmarkSlot">
                <Button Command="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).LoadBookmarkCommand}"
                        CommandParameter="{Binding}"
                        ToolTip.Tip="{Binding TooltipText}"
                        Padding="5,3" MinWidth="30" FontSize="11"
                        Background="Transparent" BorderThickness="1" BorderBrush="#555"
                        Cursor="Hand">
                  <Panel>
                    <TextBlock Text="{Binding Label}"
                               IsVisible="{Binding IsOccupied}"
                               Foreground="#4EC9B0"/>
                    <TextBlock Text="{Binding DisplayNumber}"
                               IsVisible="{Binding !IsOccupied}"
                               Foreground="#555"/>
                  </Panel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </StackPanel>

    <!-- Top toolbar row 2: Address + Export -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBox Watermark="{StaticResource str.LiveWalker.AddressHint}"
               x:Name="AddressInput"
               KeyDown="AddressInput_KeyDown"
               Width="280" Padding="4,2"/>
      <Button Content="{StaticResource str.LiveWalker.Go}"
              Command="{Binding NavigateToAddressCommand}"
              CommandParameter="{Binding #AddressInput.Text}"
              ToolTip.Tip="{StaticResource str.Tip.LiveWalker.Go}"
              Padding="8,4"/>
      <Button Content="{StaticResource str.LiveWalker.ExportCE}"
              Command="{Binding ExportCeXmlCommand}"
              IsVisible="{Binding HasData}"
              ToolTip.Tip="{StaticResource str.Tip.LiveWalker.ExportCE}"
              Padding="8,4"/>
      <Button Content="{StaticResource str.LiveWalker.ExportCEField}"
              Command="{Binding ExportCeFieldXmlCommand}"
              IsVisible="{Binding SelectedField, Converter={x:Static ObjectConverters.IsNotNull}}"
              ToolTip.Tip="{StaticResource str.Tip.LiveWalker.ExportCEField}"
              Padding="8,4"/>
      <CheckBox Content="{StaticResource str.LiveWalker.AobToggle}"
                IsChecked="{Binding UseAobSymbol}"
                IsEnabled="{Binding IsAobSymbolAvailable}"
                IsVisible="{Binding HasData}"
                ToolTip.Tip="{StaticResource str.Tip.LiveWalker.AobToggle}"
                Padding="4,2" FontSize="11" Foreground="#9CDCFE"
                VerticalAlignment="Center"/>
      <CheckBox Content="{StaticResource str.LiveWalker.GuessWhat}"
                IsChecked="{Binding FillGaps}"
                IsVisible="{Binding HasData}"
                ToolTip.Tip="{StaticResource str.Tip.LiveWalker.GuessWhat}"
                Padding="4,2" FontSize="11" Foreground="#CE9178"
                VerticalAlignment="Center"/>
      <Button Content="{StaticResource str.LiveWalker.ExportCsx}"
              Command="{Binding ExportCsxCommand}"
              IsVisible="{Binding HasData}"
              ToolTip.Tip="{StaticResource str.Tip.LiveWalker.ExportCsx}"
              Padding="8,4"/>
      <Button Content="{StaticResource str.LiveWalker.ExportHeader}"
              Command="{Binding ExportSdkHeaderCommand}"
              IsVisible="{Binding HasData}"
              ToolTip.Tip="{StaticResource str.Tip.LiveWalker.ExportHeader}"
              Padding="8,4"/>
      <Button Content="{StaticResource str.LiveWalker.GenerateCeAA}"
              Command="{Binding GenerateCeAAScriptCommand}"
              IsVisible="{Binding HasData}"
              ToolTip.Tip="{StaticResource str.Tip.LiveWalker.CeAA}"
              Padding="8,4"/>
    </StackPanel>

    <!-- Breadcrumb -->
    <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Breadcrumbs}" Margin="0,0,0,4">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:BreadcrumbItem">
          <StackPanel Orientation="Horizontal">
            <Button Content="{Binding Label}"
                    Command="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).NavigateToBreadcrumbCommand}"
                    CommandParameter="{Binding}"
                    Padding="4,2" Margin="0,0,2,0"
                    Foreground="#4EC9B0" Background="Transparent" BorderThickness="0"
                    Cursor="Hand"/>
            <TextBlock Text=">" Foreground="#666" VerticalAlignment="Center" Margin="2,0"/>
          </StackPanel>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- Object info header -->
    <Border DockPanel.Dock="Top" Background="#252525" Padding="8,4" Margin="0,0,0,4"
            IsVisible="{Binding HasData}" CornerRadius="4">
      <StackPanel Spacing="2">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Foreground="#569CD6" FontWeight="Bold">
            <Run Text="{Binding CurrentClassName}"/>
          </TextBlock>
          <TextBlock Foreground="#D4D4D4">
            <Run Text="{Binding CurrentObjectName}"/>
          </TextBlock>
          <TextBlock Foreground="#666" FontFamily="Consolas" FontSize="12">
            <Run Text="{Binding CurrentAddress}"/>
          </TextBlock>
          <!-- AOBMaker HEX button for current object address -->
          <Button Content="{StaticResource str.Pointers.AobMakerHex}"
                  Command="{Binding HexObjectAddressCommand}"
                  IsEnabled="{Binding IsAobMakerAvailable}"
                  ToolTip.Tip="{StaticResource str.LiveWalker.HexObjectTip}"
                  Padding="4,2" Margin="4,0,0,0"
                  FontSize="10" FontFamily="Consolas"
                  Foreground="#569CD6" Background="Transparent"
                  BorderThickness="1" BorderBrush="#555" Cursor="Hand"/>
          <!-- Copy buttons for current object -->
          <Button Content="Addr"
                  Command="{Binding CopyCurrentAddressCommand}"
                  Padding="3,1"
                  Foreground="#D4D4D4" Background="Transparent"
                  BorderThickness="1" BorderBrush="#555"
                  Cursor="Hand" FontSize="10"
                  ToolTip.Tip="Copy CE address"/>
          <Button Content="Name"
                  Command="{Binding CopyCurrentNameCommand}"
                  Padding="3,1"
                  Foreground="#D4D4D4" Background="Transparent"
                  BorderThickness="1" BorderBrush="#555"
                  Cursor="Hand" FontSize="10"
                  ToolTip.Tip="Copy object name"/>
        </StackPanel>
        <!-- Parent (Outer) info -->
        <StackPanel Orientation="Horizontal" Spacing="8"
                    IsVisible="{Binding HasParent}">
          <TextBlock Text="Outer:" Foreground="#888" FontSize="11"/>
          <Button Command="{Binding GoToParentCommand}"
                  Padding="2,0" Background="Transparent" BorderThickness="0"
                  Cursor="Hand">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Foreground="#C586C0" FontSize="11">
                <Run Text="{Binding CurrentOuterClassName}"/>
              </TextBlock>
              <TextBlock Foreground="#CE9178" FontSize="11">
                <Run Text="{Binding CurrentOuterName}"/>
              </TextBlock>
              <TextBlock Foreground="#666" FontFamily="Consolas" FontSize="11">
                <Run Text="{Binding CurrentOuterAddr}"/>
              </TextBlock>
            </StackPanel>
          </Button>
          <Button Content="Addr"
                  Command="{Binding CopyOuterAddressCommand}"
                  Padding="3,1"
                  Foreground="#D4D4D4" Background="Transparent"
                  BorderThickness="1" BorderBrush="#555"
                  Cursor="Hand" FontSize="10"
                  ToolTip.Tip="Copy Outer CE address"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Search bar -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4"
                IsVisible="{Binding HasData}">
      <TextBox Watermark="{StaticResource str.LiveWalker.SearchHint}"
               Text="{Binding SearchText, Mode=TwoWay}"
               Width="250" Padding="4,2" FontSize="12"/>
      <TextBlock Text="{Binding SearchMatchCount, StringFormat='{}{0} matches'}"
                 Foreground="#888" VerticalAlignment="Center" FontSize="12"
                 IsVisible="{Binding HasSearchResults}"/>
    </StackPanel>

    <!-- Loading indicator -->
    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                 IsVisible="{Binding IsLoading}" Height="2" Margin="0,0,0,4"/>
    <TextBlock DockPanel.Dock="Top" Text="{Binding StatusText}"
               Foreground="#AAB8D0" FontSize="11" Margin="4,0,0,2"
               IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

    <!-- Field list + Functions split -->
    <Grid RowDefinitions="*,Auto">
    <DataGrid x:Name="FieldGrid" Grid.Row="0"
              ItemsSource="{Binding Fields}"
              SelectedItem="{Binding SelectedField}"
              SelectionMode="Single"
              IsReadOnly="False"
              CanUserResizeColumns="True"
              CanUserSortColumns="True"
              GridLinesVisibility="Horizontal"
              BorderThickness="0"
              Background="#1E1E1E"
              FontFamily="Consolas" FontSize="12"
              HorizontalScrollBarVisibility="Auto"
              LoadingRow="FieldGrid_LoadingRow"
              BeginningEdit="FieldGrid_BeginningEdit"
              CellEditEnded="FieldGrid_CellEditEnded">
      <DataGrid.Columns>
        <DataGridTextColumn Header="{StaticResource str.ClassStruct.Offset}"
                            Binding="{Binding Offset, StringFormat='0x{0:X}'}"
                            Width="75" IsReadOnly="True"/>
        <DataGridTextColumn Header="{StaticResource str.ClassStruct.Name}"
                            Binding="{Binding Name}"
                            Width="220" MinWidth="140" IsReadOnly="True"/>
        <DataGridTextColumn Header="{StaticResource str.ClassStruct.Type}"
                            Binding="{Binding TypeName}"
                            Width="115" IsReadOnly="True"/>
        <DataGridTemplateColumn Header="{StaticResource str.LiveWalker.Value}"
                                Width="200" MinWidth="100">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="m:LiveFieldValue">
              <TextBlock Text="{Binding DisplayValue}"
                         VerticalAlignment="Center" Margin="4,0"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
          <DataGridTemplateColumn.CellEditingTemplate>
            <DataTemplate x:DataType="m:LiveFieldValue">
              <Panel>
                <!-- BoolProperty: dropdown with true/false -->
                <ComboBox IsVisible="{Binding IsBoolProperty}"
                          ItemsSource="{x:Static m:LiveFieldValue.BoolOptions}"
                          SelectedItem="{Binding EditableValue, Mode=TwoWay}"
                          Loaded="BoolCombo_Loaded"
                          SelectionChanged="BoolCombo_SelectionChanged"
                          Padding="2,1" BorderThickness="1"
                          BorderBrush="#569CD6"
                          HorizontalAlignment="Stretch"/>
                <!-- Other editable types: free-text input -->
                <TextBox IsVisible="{Binding !IsBoolProperty}"
                         Text="{Binding EditableValue, Mode=TwoWay}"
                         Padding="4,2" BorderThickness="1"
                         BorderBrush="#569CD6"/>
              </Panel>
            </DataTemplate>
          </DataGridTemplateColumn.CellEditingTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="Hex"
                            Binding="{Binding HexValue}"
                            Width="130" IsReadOnly="True"/>
        <DataGridTextColumn Header="{StaticResource str.InstanceFinder.Address}"
                            Binding="{Binding FieldAddress}"
                            Width="135" IsReadOnly="True"/>
        <DataGridTextColumn Header="{StaticResource str.LiveWalker.PtrValue}"
                            Binding="{Binding PtrAddress}"
                            Width="135" IsReadOnly="True"/>
        <DataGridTemplateColumn Header="" Width="45">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="m:LiveFieldValue">
              <StackPanel Orientation="Horizontal">
                <!-- Pointer navigation: arrow icon -->
                <Button Content="&#x2192;"
                        Command="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).NavigateToFieldCommand}"
                        CommandParameter="{Binding}"
                        IsVisible="{Binding IsPointerNavigation}"
                        Padding="8,2" Margin="2"
                        Foreground="#4EC9B0" Background="Transparent"
                        BorderThickness="1" BorderBrush="#4EC9B0"
                        Cursor="Hand" FontWeight="Bold"
                        ToolTip.Tip="Navigate to pointer target"/>
                <!-- Struct navigation: braces icon -->
                <Button Content="{}{}"
                        Command="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).NavigateToFieldCommand}"
                        CommandParameter="{Binding}"
                        IsVisible="{Binding IsStructNavigation}"
                        Padding="8,2" Margin="2"
                        Foreground="#E5C07B" Background="Transparent"
                        BorderThickness="1" BorderBrush="#E5C07B"
                        Cursor="Hand" FontWeight="Bold"
                        ToolTip.Tip="Expand inline struct"/>
                <!-- Container navigation: bracket icon (Array/Map/Set) -->
                <Button Content="[]"
                        Command="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).NavigateToContainerCommand}"
                        CommandParameter="{Binding}"
                        IsVisible="{Binding IsContainerNavigable}"
                        Padding="8,2" Margin="2"
                        Foreground="#61AFEF" Background="Transparent"
                        BorderThickness="1" BorderBrush="#61AFEF"
                        Cursor="Hand" FontWeight="Bold"
                        ToolTip.Tip="View container elements"/>
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="{StaticResource str.LiveWalker.CopyAddress}" Width="80">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="m:LiveFieldValue">
              <StackPanel Orientation="Horizontal">
                <Button Content="Addr"
                        Command="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).CopyFieldAddressCommand}"
                        CommandParameter="{Binding}"
                        ToolTip.Tip="{StaticResource str.Tip.LiveWalker.CopyFieldAddr}"
                        Padding="4,2" Margin="2"
                        Foreground="#D4D4D4" Background="Transparent"
                        BorderThickness="1" BorderBrush="#555"
                        Cursor="Hand" FontSize="10"/>
                <Button Content="{StaticResource str.Pointers.AobMakerHex}"
                        Command="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).HexFieldAddressCommand}"
                        CommandParameter="{Binding}"
                        IsEnabled="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).IsAobMakerAvailable}"
                        ToolTip.Tip="{StaticResource str.LiveWalker.HexFieldTip}"
                        Padding="3,2" Margin="0,2,2,2"
                        Foreground="#569CD6" Background="Transparent"
                        BorderThickness="1" BorderBrush="#555"
                        Cursor="Hand" FontSize="9" FontFamily="Consolas"/>
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="{StaticResource str.LiveWalker.CopyName}" Width="50">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="m:LiveFieldValue">
              <Button Content="Name"
                      Command="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).CopyFieldNameCommand}"
                      CommandParameter="{Binding}"
                      ToolTip.Tip="{StaticResource str.Tip.LiveWalker.CopyFieldName}"
                      Padding="4,2" Margin="2"
                      Foreground="#D4D4D4" Background="Transparent"
                      BorderThickness="1" BorderBrush="#555"
                      Cursor="Hand" FontSize="10"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="{StaticResource str.LiveWalker.CopyPtr}" Width="80">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="m:LiveFieldValue">
              <StackPanel Orientation="Horizontal"
                          IsVisible="{Binding IsPointerNavigation}">
                <Button Content="Ptr"
                        Command="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).CopyPtrAddressCommand}"
                        CommandParameter="{Binding}"
                        Padding="4,2" Margin="2"
                        Foreground="#4EC9B0" Background="Transparent"
                        BorderThickness="1" BorderBrush="#555"
                        Cursor="Hand" FontSize="10"
                        ToolTip.Tip="Copy pointer target address"/>
                <Button Content="{StaticResource str.Pointers.AobMakerHex}"
                        Command="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).HexPtrAddressCommand}"
                        CommandParameter="{Binding}"
                        IsEnabled="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).IsAobMakerAvailable}"
                        ToolTip.Tip="{StaticResource str.LiveWalker.HexPtrTip}"
                        Padding="3,2" Margin="0,2,2,2"
                        Foreground="#4EC9B0" Background="Transparent"
                        BorderThickness="1" BorderBrush="#555"
                        Cursor="Hand" FontSize="9" FontFamily="Consolas"/>
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>

    <!-- Functions section (collapsible) -->
    <Expander Grid.Row="1" IsVisible="{Binding HasFunctions}"
              Header="{StaticResource str.LiveWalker.Functions}"
              IsExpanded="False" Margin="0,4,0,0"
              MaxHeight="280">
      <DataGrid x:Name="FunctionGrid"
                ItemsSource="{Binding Functions}"
                SelectedItem="{Binding SelectedFunction}"
                IsReadOnly="True"
                CanUserResizeColumns="True"
                GridLinesVisibility="Horizontal"
                BorderThickness="0"
                Background="#1E1E1E"
                FontFamily="Consolas" FontSize="12"
                Focusable="False">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200" MinWidth="120"/>
          <DataGridTextColumn Header="Return" Binding="{Binding ReturnType}" Width="100"/>
          <DataGridTextColumn Header="Params" Width="90">
            <DataGridTextColumn.Binding>
              <MultiBinding StringFormat="{}{0} ({1}B)">
                <Binding Path="NumParms"/>
                <Binding Path="ParmsSize"/>
              </MultiBinding>
            </DataGridTextColumn.Binding>
          </DataGridTextColumn>
          <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="140"/>
          <DataGridTemplateColumn Header="" Width="100">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="m:FunctionInfoModel">
                <StackPanel Orientation="Horizontal" Spacing="2">
                  <Button Content="{StaticResource str.LiveWalker.FuncGenScript}"
                          Command="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).GenerateInvokeScriptCommand}"
                          CommandParameter="{Binding}"
                          IsEnabled="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).IsAobMakerAvailable}"
                          Padding="6,2" Margin="2,2,0,2"
                          Foreground="#DCDCAA" Background="Transparent"
                          BorderThickness="1" BorderBrush="#DCDCAA"
                          Cursor="Hand" FontWeight="Bold" FontSize="11"
                          ToolTip.Tip="{StaticResource str.Tip.LiveWalker.FuncGenScript}"
                          ClickMode="Press"/>
                  <Button Content="{StaticResource str.LiveWalker.FuncPipeInvoke}"
                          Command="{Binding $parent[UserControl].((vm:LiveWalkerViewModel)DataContext).InvokeViaPipeCommand}"
                          CommandParameter="{Binding}"
                          Padding="6,2" Margin="0,2,2,2"
                          Foreground="#4EC9B0" Background="Transparent"
                          BorderThickness="1" BorderBrush="#4EC9B0"
                          Cursor="Hand" FontWeight="Bold" FontSize="11"
                          ToolTip.Tip="{StaticResource str.Tip.LiveWalker.FuncPipeInvoke}"
                          ClickMode="Press"/>
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Expander>
    </Grid>
  </DockPanel>
</UserControl>
