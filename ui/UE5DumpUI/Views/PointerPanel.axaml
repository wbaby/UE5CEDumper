<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UE5DumpUI.ViewModels"
             x:Class="UE5DumpUI.Views.PointerPanel"
             x:DataType="vm:PointerPanelViewModel">

  <StackPanel Margin="16" Spacing="16">
    <!-- Not connected message -->
    <TextBlock Text="{StaticResource str.Pointers.NotConnected}"
               Foreground="#666" FontSize="14"
               IsVisible="{Binding !HasData}"
               HorizontalAlignment="Center" Margin="0,40,0,0"/>

    <!-- Pointer info cards -->
    <StackPanel Spacing="12" IsVisible="{Binding HasData}">

      <!-- UE Version -->
      <Border Background="#2D2D30" CornerRadius="4" Padding="16,12">
        <StackPanel>
          <TextBlock Text="{StaticResource str.Pointers.UEVersion}"
                     Foreground="#888" FontSize="12"/>
          <TextBlock Text="{Binding UeVersion}" FontSize="20"
                     Foreground="#4EC9B0" FontWeight="SemiBold"/>
          <TextBlock Text="{StaticResource str.Pointers.VersionWarning}"
                     Foreground="#E6A817" FontSize="11" TextWrapping="Wrap"
                     Margin="0,4,0,0"
                     IsVisible="{Binding ShowVersionWarning}"/>
        </StackPanel>
      </Border>

      <!-- GObjects -->
      <Border Background="#2D2D30" CornerRadius="4" Padding="16,12">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel>
            <TextBlock Text="{StaticResource str.Pointers.GObjects}"
                       Foreground="#888" FontSize="12"/>
            <TextBlock Text="{Binding GObjectsAddress}" FontSize="16"
                       Foreground="#569CD6" FontFamily="Consolas"/>
            <TextBlock Text="{Binding GObjectsPatternId}" FontSize="10"
                       Foreground="#666" FontFamily="Consolas" Margin="0,2,0,0"
                       IsVisible="{Binding HasGObjectsPatternId}"
                       ToolTip.Tip="{StaticResource str.Pointers.PatternIdTooltip}"/>
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0"
                        IsVisible="{Binding HasGObjectsScanAddr}">
              <TextBlock Text="AOB:" Foreground="#888" FontSize="10"/>
              <TextBlock Text="{Binding GObjectsScanAddr}" FontSize="10"
                         Foreground="#E5C07B" FontFamily="Consolas"/>
              <Button Content="Copy" Command="{Binding CopyGObjectsScanAddrCommand}"
                      Padding="4,1" FontSize="9" Foreground="#AAA" Background="Transparent"
                      BorderThickness="1" BorderBrush="#555" Cursor="Hand"/>
            </StackPanel>
            <TextBlock Text="{StaticResource str.Pointers.AobAllFailed}"
                       Foreground="#E05252" FontSize="11" Margin="0,3,0,0"
                       IsVisible="{Binding GObjectsAobAllFailed}"/>
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,3,0,0"
                        IsVisible="{Binding ShowGObjectsWarning}">
              <TextBlock Text="{StaticResource str.Pointers.AobFailed}"
                         Foreground="#E6A817" FontSize="11"/>
              <TextBlock Text="{Binding GObjectsMethodLabel}"
                         Foreground="#E6A817" FontSize="11" FontWeight="SemiBold"/>
            </StackPanel>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                      VerticalAlignment="Center">
            <Button Content="{StaticResource str.Pointers.AobMakerAsm}"
                    Command="{Binding AsmGObjectsCommand}"
                    IsEnabled="{Binding CanAsmGObjects}"
                    ToolTip.Tip="{StaticResource str.Pointers.AobMakerAsmTip}"
                    Padding="6,4" FontSize="11" FontFamily="Consolas"
                    Foreground="#E5C07B" Background="Transparent"
                    BorderThickness="1" BorderBrush="#555"/>
            <Button Content="{StaticResource str.Pointers.AobMakerHex}"
                    Command="{Binding HexGObjectsCommand}"
                    IsEnabled="{Binding CanHexGObjects}"
                    ToolTip.Tip="{StaticResource str.Pointers.AobMakerHexTip}"
                    Padding="6,4" FontSize="11" FontFamily="Consolas"
                    Foreground="#569CD6" Background="Transparent"
                    BorderThickness="1" BorderBrush="#555"/>
            <Button Content="{StaticResource str.Pointers.Copy}"
                    Command="{Binding CopyGObjectsCommand}"
                    Padding="8,4"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- GNames -->
      <Border Background="#2D2D30" CornerRadius="4" Padding="16,12">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel>
            <TextBlock Text="{StaticResource str.Pointers.GNames}"
                       Foreground="#888" FontSize="12"/>
            <TextBlock Text="{Binding GNamesAddress}" FontSize="16"
                       Foreground="#569CD6" FontFamily="Consolas"/>
            <TextBlock Text="{Binding GNamesPatternId}" FontSize="10"
                       Foreground="#666" FontFamily="Consolas" Margin="0,2,0,0"
                       IsVisible="{Binding HasGNamesPatternId}"
                       ToolTip.Tip="{StaticResource str.Pointers.PatternIdTooltip}"/>
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0"
                        IsVisible="{Binding HasGNamesScanAddr}">
              <TextBlock Text="AOB:" Foreground="#888" FontSize="10"/>
              <TextBlock Text="{Binding GNamesScanAddr}" FontSize="10"
                         Foreground="#E5C07B" FontFamily="Consolas"/>
              <Button Content="Copy" Command="{Binding CopyGNamesScanAddrCommand}"
                      Padding="4,1" FontSize="9" Foreground="#AAA" Background="Transparent"
                      BorderThickness="1" BorderBrush="#555" Cursor="Hand"/>
            </StackPanel>
            <TextBlock Text="{StaticResource str.Pointers.AobAllFailed}"
                       Foreground="#E05252" FontSize="11" Margin="0,3,0,0"
                       IsVisible="{Binding GNamesAobAllFailed}"/>
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,3,0,0"
                        IsVisible="{Binding ShowGNamesWarning}">
              <TextBlock Text="{StaticResource str.Pointers.AobFailed}"
                         Foreground="#E6A817" FontSize="11"/>
              <TextBlock Text="{Binding GNamesMethodLabel}"
                         Foreground="#E6A817" FontSize="11" FontWeight="SemiBold"/>
            </StackPanel>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                      VerticalAlignment="Center">
            <Button Content="{StaticResource str.Pointers.AobMakerAsm}"
                    Command="{Binding AsmGNamesCommand}"
                    IsEnabled="{Binding CanAsmGNames}"
                    ToolTip.Tip="{StaticResource str.Pointers.AobMakerAsmTip}"
                    Padding="6,4" FontSize="11" FontFamily="Consolas"
                    Foreground="#E5C07B" Background="Transparent"
                    BorderThickness="1" BorderBrush="#555"/>
            <Button Content="{StaticResource str.Pointers.AobMakerHex}"
                    Command="{Binding HexGNamesCommand}"
                    IsEnabled="{Binding CanHexGNames}"
                    ToolTip.Tip="{StaticResource str.Pointers.AobMakerHexTip}"
                    Padding="6,4" FontSize="11" FontFamily="Consolas"
                    Foreground="#569CD6" Background="Transparent"
                    BorderThickness="1" BorderBrush="#555"/>
            <Button Content="{StaticResource str.Pointers.Copy}"
                    Command="{Binding CopyGNamesCommand}"
                    Padding="8,4"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- GWorld -->
      <Border Background="#2D2D30" CornerRadius="4" Padding="16,12">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel>
            <TextBlock Text="{StaticResource str.Pointers.GWorld}"
                       Foreground="#888" FontSize="12"/>
            <TextBlock Text="{Binding GWorldAddress}" FontSize="16"
                       Foreground="#569CD6" FontFamily="Consolas"/>
            <TextBlock Text="{Binding GWorldPatternId}" FontSize="10"
                       Foreground="#666" FontFamily="Consolas" Margin="0,2,0,0"
                       IsVisible="{Binding HasGWorldPatternId}"
                       ToolTip.Tip="{StaticResource str.Pointers.PatternIdTooltip}"/>
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0"
                        IsVisible="{Binding HasGWorldScanAddr}">
              <TextBlock Text="AOB:" Foreground="#888" FontSize="10"/>
              <TextBlock Text="{Binding GWorldScanAddr}" FontSize="10"
                         Foreground="#E5C07B" FontFamily="Consolas"/>
              <Button Content="Copy" Command="{Binding CopyGWorldScanAddrCommand}"
                      Padding="4,1" FontSize="9" Foreground="#AAA" Background="Transparent"
                      BorderThickness="1" BorderBrush="#555" Cursor="Hand"/>
            </StackPanel>
            <TextBlock Text="{StaticResource str.Pointers.AobAllFailed}"
                       Foreground="#E05252" FontSize="11" Margin="0,3,0,0"
                       IsVisible="{Binding GWorldAobAllFailed}"/>
            <TextBlock Text="{StaticResource str.Pointers.GWorldNotFound}"
                       Foreground="#888" FontSize="11" Margin="0,3,0,0"
                       IsVisible="{Binding ShowGWorldWarning}"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                      VerticalAlignment="Center">
            <Button Content="{StaticResource str.Pointers.AobMakerAsm}"
                    Command="{Binding AsmGWorldCommand}"
                    IsEnabled="{Binding CanAsmGWorld}"
                    ToolTip.Tip="{StaticResource str.Pointers.AobMakerAsmTip}"
                    Padding="6,4" FontSize="11" FontFamily="Consolas"
                    Foreground="#E5C07B" Background="Transparent"
                    BorderThickness="1" BorderBrush="#555"/>
            <Button Content="{StaticResource str.Pointers.AobMakerHex}"
                    Command="{Binding HexGWorldCommand}"
                    IsEnabled="{Binding CanHexGWorld}"
                    ToolTip.Tip="{StaticResource str.Pointers.AobMakerHexTip}"
                    Padding="6,4" FontSize="11" FontFamily="Consolas"
                    Foreground="#569CD6" Background="Transparent"
                    BorderThickness="1" BorderBrush="#555"/>
            <Button Content="{StaticResource str.Pointers.Copy}"
                    Command="{Binding CopyGWorldCommand}"
                    Padding="8,4"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Total Objects -->
      <Border Background="#2D2D30" CornerRadius="4" Padding="16,12">
        <StackPanel>
          <TextBlock Text="{StaticResource str.Pointers.TotalObjects}"
                     Foreground="#888" FontSize="12"/>
          <TextBlock Text="{Binding TotalObjects}" FontSize="20"
                     Foreground="#B5CEA8" FontWeight="SemiBold"/>
        </StackPanel>
      </Border>

      <!-- Extra Scan — visible only when some pointers are missing -->
      <Border Background="#2D2D30" CornerRadius="4" Padding="16,12"
              IsVisible="{Binding CanExtraScan}">
        <StackPanel Spacing="8">
          <TextBlock Text="{StaticResource str.Pointers.ExtraScanHint}"
                     Foreground="#888" FontSize="12" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="{StaticResource str.Pointers.ExtraScan}"
                    Command="{Binding ExtraScanCommand}"
                    IsEnabled="{Binding !IsScanning}"
                    Padding="12,6"/>
          </StackPanel>
          <StackPanel IsVisible="{Binding IsScanning}" Orientation="Horizontal" Spacing="8">
            <ProgressBar IsIndeterminate="True" Width="120" Height="8"
                         VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ScanStatusText}" Foreground="#4EC9B0"
                       FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock Text="{Binding ScanResultText}" Foreground="#4EC9B0"
                     FontSize="12" TextWrapping="Wrap"
                     IsVisible="{Binding ScanComplete}"/>
        </StackPanel>
      </Border>

      <!-- Test Extra Scan — always visible for development testing -->
      <Border Background="#2D2D30" CornerRadius="4" Padding="16,12"
              BorderBrush="#555" BorderThickness="1">
        <StackPanel Spacing="6">
          <TextBlock Text="{StaticResource str.Pointers.TestExtraScanHint}"
                     Foreground="#666" FontSize="11" TextWrapping="Wrap"/>
          <Button Content="{StaticResource str.Pointers.TestExtraScan}"
                  Command="{Binding TestExtraScanCommand}"
                  IsEnabled="{Binding !IsScanning}"
                  Padding="8,4" FontSize="11" Foreground="#AAA"
                  Background="Transparent" BorderThickness="1" BorderBrush="#555"/>
          <StackPanel IsVisible="{Binding IsScanning}" Orientation="Horizontal" Spacing="8">
            <ProgressBar IsIndeterminate="True" Width="100" Height="6"
                         VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ScanStatusText}" Foreground="#888"
                       FontSize="11" VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </StackPanel>
</UserControl>
