<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UE5DumpUI.ViewModels"
             xmlns:m="using:UE5DumpUI.Models"
             x:Class="UE5DumpUI.Views.InstanceFinderPanel"
             x:DataType="vm:InstanceFinderViewModel">

  <DockPanel Margin="8">
    <!-- Top: Search bar -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBox Watermark="{StaticResource str.InstanceFinder.ClassNameHint}"
               Text="{Binding SearchClassName}"
               x:Name="SearchClassNameInput"
               KeyDown="SearchClassNameInput_KeyDown"
               Width="300" Padding="4,2"/>
      <Button Content="{StaticResource str.InstanceFinder.Search}"
              Command="{Binding SearchCommand}"
              Classes="accent" Padding="12,4"/>
      <TextBlock Text="{Binding StatusText}"
                 Foreground="#888" VerticalAlignment="Center" Margin="8,0"/>
    </StackPanel>

    <!-- Loading (class search) -->
    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                 IsVisible="{Binding IsSearching}" Height="2" Margin="0,0,0,4"/>

    <!-- Address-to-Instance reverse lookup -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBox Watermark="{StaticResource str.InstanceFinder.AddressHint}"
               Text="{Binding LookupAddress}"
               x:Name="LookupAddressInput"
               KeyDown="LookupAddressInput_KeyDown"
               Width="300" Padding="4,2"/>
      <Button Content="{StaticResource str.InstanceFinder.Lookup}"
              Command="{Binding LookupAddressCommand}"
              Padding="12,4"/>
      <TextBlock Text="{Binding LookupStatusText}"
                 Foreground="#888" VerticalAlignment="Center" Margin="8,0"/>
    </StackPanel>

    <!-- Loading (address lookup) -->
    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                 IsVisible="{Binding IsLookingUp}" Height="2" Margin="0,0,0,4"/>

    <!-- Main content: instances list (top) + field values (bottom) -->
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="200" MinHeight="100"/>
        <RowDefinition Height="4"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Instance list -->
      <DataGrid Grid.Row="0"
                ItemsSource="{Binding Instances}"
                SelectedItem="{Binding SelectedInstance}"
                IsReadOnly="True"
                CanUserResizeColumns="True"
                GridLinesVisibility="Horizontal"
                BorderThickness="0"
                Background="#1E1E1E"
                FontFamily="Consolas" FontSize="12">
        <DataGrid.Columns>
          <DataGridTextColumn Header="{StaticResource str.InstanceFinder.Address}"
                              Binding="{Binding Address}"
                              Width="160"/>
          <DataGridTextColumn Header="{StaticResource str.ClassStruct.Name}"
                              Binding="{Binding Name}"
                              Width="200"/>
          <DataGridTextColumn Header="{StaticResource str.ClassStruct.Type}"
                              Binding="{Binding ClassName}"
                              Width="200"/>
          <DataGridTextColumn Header="Index"
                              Binding="{Binding Index}"
                              Width="80"/>
          <DataGridTemplateColumn Header="{StaticResource str.InstanceFinder.CopyAddress}" Width="50">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="m:InstanceResult">
                <Button Content="Addr"
                        Command="{Binding $parent[UserControl].((vm:InstanceFinderViewModel)DataContext).CopyInstanceAddressCommand}"
                        CommandParameter="{Binding}"
                        Padding="4,2" Margin="2"
                        Foreground="#D4D4D4" Background="Transparent"
                        BorderThickness="1" BorderBrush="#555"
                        Cursor="Hand" FontSize="10"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="{StaticResource str.LiveWalker.GenerateCeAA}" Width="60">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="m:InstanceResult">
                <Button Content="AA"
                        Command="{Binding $parent[UserControl].((vm:InstanceFinderViewModel)DataContext).GenerateCeAAScriptCommand}"
                        CommandParameter="{Binding}"
                        Padding="4,2" Margin="2"
                        Foreground="#E5C07B" Background="Transparent"
                        BorderThickness="1" BorderBrush="#E5C07B"
                        Cursor="Hand" FontSize="10"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>

      <GridSplitter Grid.Row="1" Background="#3C3C3C" ResizeDirection="Rows"/>

      <!-- Field values for selected instance -->
      <DockPanel Grid.Row="2">
        <!-- Action buttons -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8"
                    Margin="0,4,0,4" IsVisible="{Binding HasFields}">
          <Button Content="{StaticResource str.LiveWalker.ExportCE}"
                  Command="{Binding ExportCeXmlCommand}"
                  Padding="8,4"/>
          <Button Content="{StaticResource str.InstanceFinder.OpenInWalker}"
                  Command="{Binding OpenInLiveWalkerCommand}"
                  Padding="8,4"/>
        </StackPanel>

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                     IsVisible="{Binding IsLoadingFields}" Height="2" Margin="0,0,0,4"/>

        <DataGrid ItemsSource="{Binding Fields}"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="#1E1E1E"
                  FontFamily="Consolas" FontSize="12">
          <DataGrid.Columns>
            <DataGridTextColumn Header="{StaticResource str.ClassStruct.Offset}"
                                Binding="{Binding Offset, StringFormat='0x{0:X}'}"
                                Width="80"/>
            <DataGridTextColumn Header="{StaticResource str.ClassStruct.Name}"
                                Binding="{Binding Name}"
                                Width="200"/>
            <DataGridTextColumn Header="{StaticResource str.ClassStruct.Type}"
                                Binding="{Binding TypeName}"
                                Width="140"/>
            <DataGridTextColumn Header="{StaticResource str.LiveWalker.Value}"
                                Binding="{Binding DisplayValue}"
                                Width="200"/>
            <DataGridTextColumn Header="Hex"
                                Binding="{Binding HexValue}" Width="160"/>
            <DataGridTextColumn Header="{StaticResource str.InstanceFinder.Address}"
                                Binding="{Binding FieldAddress}"
                                Width="140"/>
            <DataGridTemplateColumn Header="{StaticResource str.LiveWalker.CopyAddress}" Width="50">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="m:LiveFieldValue">
                  <Button Content="Addr"
                          Command="{Binding $parent[UserControl].((vm:InstanceFinderViewModel)DataContext).CopyFieldAddressCommand}"
                          CommandParameter="{Binding}"
                          Padding="4,2" Margin="2"
                          Foreground="#D4D4D4" Background="Transparent"
                          BorderThickness="1" BorderBrush="#555"
                          Cursor="Hand" FontSize="10"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </Grid>
  </DockPanel>
</UserControl>
