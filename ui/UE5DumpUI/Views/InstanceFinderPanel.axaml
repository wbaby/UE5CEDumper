<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UE5DumpUI.ViewModels"
             xmlns:m="using:UE5DumpUI.Models"
             x:Class="UE5DumpUI.Views.InstanceFinderPanel"
             x:DataType="vm:InstanceFinderViewModel">

  <DockPanel Margin="8">
    <!-- Top: Search bar -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBox Watermark="{DynamicResource str.InstanceFinder.ClassNameHint}"
               Text="{Binding SearchClassName}"
               Width="300" Padding="4,2"/>
      <Button Content="{DynamicResource str.InstanceFinder.Search}"
              Command="{Binding SearchCommand}"
              Classes="accent" Padding="12,4"/>
      <TextBlock Text="{Binding StatusText}"
                 Foreground="#888" VerticalAlignment="Center" Margin="8,0"/>
    </StackPanel>

    <!-- Loading -->
    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                 IsVisible="{Binding IsSearching}" Height="2" Margin="0,0,0,4"/>

    <!-- CE XML output -->
    <Border DockPanel.Dock="Bottom" IsVisible="{Binding ShowCeXml}"
            Background="#1A1A2E" Padding="8" CornerRadius="4" MaxHeight="200"
            Margin="0,4,0,0">
      <ScrollViewer>
        <SelectableTextBlock Text="{Binding CeXmlOutput}"
                             FontFamily="Consolas" FontSize="11"
                             Foreground="#98C379"/>
      </ScrollViewer>
    </Border>

    <!-- Main content: instances list (top) + field values (bottom) -->
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="200" MinHeight="100"/>
        <RowDefinition Height="4"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Instance list -->
      <DataGrid Grid.Row="0"
                ItemsSource="{Binding Instances}"
                SelectedItem="{Binding SelectedInstance}"
                IsReadOnly="True"
                CanUserResizeColumns="True"
                GridLinesVisibility="Horizontal"
                BorderThickness="0"
                Background="#1E1E1E"
                FontFamily="Consolas" FontSize="12">
        <DataGrid.Columns>
          <DataGridTextColumn Header="{DynamicResource str.InstanceFinder.Address}"
                              Binding="{Binding Address}"
                              Width="160"/>
          <DataGridTextColumn Header="{DynamicResource str.ClassStruct.Name}"
                              Binding="{Binding Name}"
                              Width="200"/>
          <DataGridTextColumn Header="{DynamicResource str.ClassStruct.Type}"
                              Binding="{Binding ClassName}"
                              Width="200"/>
          <DataGridTextColumn Header="Index"
                              Binding="{Binding Index}"
                              Width="80"/>
        </DataGrid.Columns>
      </DataGrid>

      <GridSplitter Grid.Row="1" Background="#3C3C3C" ResizeDirection="Rows"/>

      <!-- Field values for selected instance -->
      <DockPanel Grid.Row="2">
        <!-- Action buttons -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8"
                    Margin="0,4,0,4" IsVisible="{Binding HasFields}">
          <Button Content="{DynamicResource str.LiveWalker.ExportCE}"
                  Command="{Binding ExportCeXmlCommand}"
                  Padding="8,4"/>
          <Button Content="{DynamicResource str.InstanceFinder.OpenInWalker}"
                  Command="{Binding OpenInLiveWalkerCommand}"
                  Padding="8,4"/>
        </StackPanel>

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                     IsVisible="{Binding IsLoadingFields}" Height="2" Margin="0,0,0,4"/>

        <DataGrid ItemsSource="{Binding Fields}"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="#1E1E1E"
                  FontFamily="Consolas" FontSize="12">
          <DataGrid.Columns>
            <DataGridTextColumn Header="{DynamicResource str.ClassStruct.Offset}"
                                Binding="{Binding Offset, StringFormat='0x{0:X}'}"
                                Width="80"/>
            <DataGridTextColumn Header="{DynamicResource str.ClassStruct.Name}"
                                Binding="{Binding Name}"
                                Width="200"/>
            <DataGridTextColumn Header="{DynamicResource str.ClassStruct.Type}"
                                Binding="{Binding TypeName}"
                                Width="140"/>
            <DataGridTextColumn Header="{DynamicResource str.LiveWalker.Value}"
                                Binding="{Binding DisplayValue}"
                                Width="200"/>
            <DataGridTextColumn Header="Hex"
                                Binding="{Binding HexValue}"
                                Width="*"/>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </Grid>
  </DockPanel>
</UserControl>
