<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UE5DumpUI.ViewModels"
             xmlns:m="using:UE5DumpUI.Models"
             x:Class="UE5DumpUI.Views.GameClassFilterPanel"
             x:DataType="vm:GameClassFilterViewModel">

  <DockPanel Margin="8">
    <!-- Row 1: Load + GameOnly + Status -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
      <Button Content="{StaticResource str.GameClassFilter.Load}"
              Command="{Binding LoadCommand}"
              ToolTip.Tip="{StaticResource str.Tip.GameClassFilter.Load}"
              Classes="accent" Padding="12,4"/>
      <CheckBox Content="{StaticResource str.GameClassFilter.GameOnly}"
                IsChecked="{Binding GameClassesOnly}"
                ToolTip.Tip="{StaticResource str.Tip.GameClassFilter.GameOnly}"
                Foreground="#CCCCCC" FontSize="12"
                VerticalAlignment="Center"/>
      <TextBlock Text="{Binding StatusText}"
                 Foreground="#888" VerticalAlignment="Center" Margin="8,0"/>
    </StackPanel>

    <!-- Row 2: Filters -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
      <TextBlock Text="{StaticResource str.GameClassFilter.SuperLabel}"
                 Foreground="#AAA" VerticalAlignment="Center" FontSize="12"/>
      <AutoCompleteBox Watermark="{StaticResource str.GameClassFilter.SuperHint}"
                       Text="{Binding SuperFilter}"
                       FilterMode="Contains"
                       ItemsSource="{Binding SuperSuggestions}"
                       MinimumPrefixLength="0"
                       ToolTip.Tip="{StaticResource str.Tip.GameClassFilter.SuperFilter}"
                       Width="180" Padding="4,2" FontSize="12"/>
      <TextBlock Text="{StaticResource str.GameClassFilter.PackageLabel}"
                 Foreground="#AAA" VerticalAlignment="Center" FontSize="12"/>
      <AutoCompleteBox Watermark="{StaticResource str.GameClassFilter.PackageHint}"
                       Text="{Binding PackageFilter}"
                       FilterMode="Contains"
                       ItemsSource="{Binding PackageSuggestions}"
                       MinimumPrefixLength="0"
                       ToolTip.Tip="{StaticResource str.Tip.GameClassFilter.PackageFilter}"
                       Width="180" Padding="4,2" FontSize="12"/>
      <TextBox Watermark="{StaticResource str.GameClassFilter.FilterHint}"
               Text="{Binding FilterText}"
               Width="200" Padding="4,2"/>
      <Button Content="{StaticResource str.GameClassFilter.Clear}"
              Command="{Binding ClearFiltersCommand}"
              ToolTip.Tip="{StaticResource str.Tip.GameClassFilter.Clear}"
              Padding="8,4" FontSize="11"/>
    </StackPanel>

    <!-- Loading indicator -->
    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True"
                 IsVisible="{Binding IsLoading}" Height="2" Margin="0,0,0,4"/>

    <!-- Error display -->
    <TextBlock DockPanel.Dock="Top"
               Text="{Binding ErrorMessage}"
               Foreground="#F44747" Margin="0,0,0,4"
               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

    <!-- Results DataGrid -->
    <DataGrid ItemsSource="{Binding Results}"
              SelectedItem="{Binding SelectedResult}"
              IsReadOnly="True"
              CanUserResizeColumns="True"
              GridLinesVisibility="Horizontal"
              BorderThickness="0"
              Background="#1E1E1E"
              Foreground="#D4D4D4"
              FontSize="12"
              FontFamily="Consolas, Menlo, monospace">
      <DataGrid.Columns>
        <DataGridTemplateColumn Header="Score" Width="55">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="m:GameClassEntry">
              <TextBlock Text="{Binding Score}" Foreground="#E5C07B"
                         VerticalAlignment="Center" Margin="4,0"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="Class"
                            Binding="{Binding ClassName}"
                            Width="220"/>
        <DataGridTextColumn Header="Super"
                            Binding="{Binding SuperName}"
                            Width="160"/>
        <DataGridTextColumn Header="Path"
                            Binding="{Binding ClassPath}"
                            Width="280"/>
        <DataGridTextColumn Header="Props"
                            Binding="{Binding PropertyCount}"
                            Width="60"/>
        <DataGridTextColumn Header="Size"
                            Binding="{Binding SizeHex}"
                            Width="70"/>
        <DataGridTemplateColumn Header="" Width="Auto">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate x:DataType="m:GameClassEntry">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="{StaticResource str.GameClassFilter.FindInstances}"
                        Command="{Binding $parent[UserControl].((vm:GameClassFilterViewModel)DataContext).FindInstancesCommand}"
                        CommandParameter="{Binding}"
                        ToolTip.Tip="{StaticResource str.Tip.GameClassFilter.FindInstances}"
                        Padding="6,2" FontSize="11"/>
                <Button Content="{StaticResource str.GameClassFilter.WalkClass}"
                        Command="{Binding $parent[UserControl].((vm:GameClassFilterViewModel)DataContext).WalkClassCommand}"
                        CommandParameter="{Binding}"
                        ToolTip.Tip="{StaticResource str.Tip.GameClassFilter.WalkClass}"
                        Padding="6,2" FontSize="11"/>
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
