<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UE5DumpUI.ViewModels"
             xmlns:models="using:UE5DumpUI.Models"
             x:Class="UE5DumpUI.Views.ObjectTreePanel"
             x:DataType="vm:ObjectTreeViewModel">

  <DockPanel>
    <!-- Search bar -->
    <StackPanel DockPanel.Dock="Top" Margin="4" Spacing="4">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="{StaticResource str.ObjectTree.Title}"
                   FontWeight="SemiBold" FontSize="14" Foreground="#CCC"/>
        <TextBlock Text="{Binding DisplayCount}"
                   Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
      </StackPanel>

      <Grid ColumnDefinitions="*,Auto,Auto,Auto">
        <AutoCompleteBox Grid.Column="0"
                 Watermark="{StaticResource str.ObjectTree.Search}"
                 Text="{Binding SearchText}"
                 FilterMode="Contains"
                 ItemsSource="{Binding SearchSuggestions}"
                 Margin="0,0,4,0"
                 KeyDown="SearchBox_KeyDown"
                 IsEnabled="{Binding !IsLoading}"
                 x:Name="SearchBox"/>
        <Button Grid.Column="1"
                Content="{StaticResource str.ObjectTree.Load}"
                Command="{Binding LoadCommand}"
                IsVisible="{Binding !IsLoading}"
                Margin="0,0,4,0" Padding="8,4"/>
        <Button Grid.Column="1"
                Content="{StaticResource str.ObjectTree.Cancel}"
                Command="{Binding CancelLoadCommand}"
                IsVisible="{Binding IsLoading}"
                Margin="0,0,4,0" Padding="8,4"
                Foreground="#F44747"/>
        <Button Grid.Column="2"
                Content="&#x1F50D;"
                Command="{Binding SearchCommand}"
                IsEnabled="{Binding !IsLoading}"
                Padding="8,4"/>
      </Grid>

      <!-- Status text (shown during search/load operations) -->
      <TextBlock Text="{Binding StatusText}"
                 Foreground="#888" FontSize="12"
                 IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                 Margin="0,0,0,2"/>

      <!-- Class type + text filter -->
      <StackPanel Orientation="Horizontal" Spacing="4">
        <TextBlock Text="{StaticResource str.ObjectTree.ClassFilter}"
                   Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
        <ComboBox ItemsSource="{Binding ClassFilterOptions}"
                  SelectedIndex="{Binding SelectedClassFilterIndex}"
                  MinWidth="140" Padding="4,2" FontSize="12"/>
        <TextBox Watermark="{StaticResource str.ObjectTree.FilterHint}"
                 Text="{Binding FilterText}"
                 Padding="4,2" FontSize="12"
                 MinWidth="160"/>
      </StackPanel>
    </StackPanel>

    <!-- Object list (flat list with virtualization) -->
    <ListBox ItemsSource="{Binding FilteredNodes}"
             SelectedItem="{Binding SelectedNode}"
             Background="Transparent">
      <!-- ContextMenu on ListBox: uses SelectedNode for commands (works on full row area) -->
      <ListBox.ContextMenu>
        <ContextMenu>
          <MenuItem Header="{StaticResource str.ObjectTree.CopyClassName}"
                    Command="{Binding CopyClassNameCommand}"
                    CommandParameter="{Binding SelectedNode}"/>
          <MenuItem Header="{StaticResource str.ObjectTree.CopyObjectName}"
                    Command="{Binding CopyObjectNameCommand}"
                    CommandParameter="{Binding SelectedNode}"/>
          <MenuItem Header="{StaticResource str.ObjectTree.CopyAddress}"
                    Command="{Binding CopyAddressCommand}"
                    CommandParameter="{Binding SelectedNode}"/>
        </ContextMenu>
      </ListBox.ContextMenu>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="models:UObjectNode">
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="2,1">
            <TextBlock Text="{Binding ClassName}"
                       Foreground="#569CD6" FontSize="14"
                       FontWeight="SemiBold"
                       MinWidth="140"/>
            <TextBlock Text="{Binding Name}"
                       Foreground="#D4D4D4" FontSize="14"/>
            <TextBlock Text="{Binding Address}"
                       Foreground="#6A9955" FontSize="13"
                       Opacity="0.7"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</UserControl>
