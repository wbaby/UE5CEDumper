<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UE5DumpUI.ViewModels"
             xmlns:models="using:UE5DumpUI.Models"
             x:Class="UE5DumpUI.Views.ObjectTreePanel"
             x:DataType="vm:ObjectTreeViewModel">

  <DockPanel>
    <!-- Search bar -->
    <StackPanel DockPanel.Dock="Top" Margin="4" Spacing="4">
      <TextBlock Text="{DynamicResource str.ObjectTree.Title}"
                 FontWeight="SemiBold" FontSize="14" Foreground="#CCC"/>

      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBox Grid.Column="0"
                 Watermark="{DynamicResource str.ObjectTree.Search}"
                 Text="{Binding SearchText}"
                 Margin="0,0,4,0"/>
        <Button Grid.Column="1"
                Content="{DynamicResource str.ObjectTree.Load}"
                Command="{Binding LoadCommand}"
                Margin="0,0,4,0" Padding="8,4"/>
        <Button Grid.Column="2"
                Content="&#x1F50D;"
                Command="{Binding SearchCommand}"
                Padding="8,4"/>
      </Grid>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="{Binding ObjectCount, StringFormat='Objects: {0}'}"
                   Foreground="#888" FontSize="12"/>
        <TextBlock Text="{DynamicResource str.ObjectTree.Loading}"
                   Foreground="#4EC9B0" FontSize="12"
                   IsVisible="{Binding IsLoading}"/>
      </StackPanel>
    </StackPanel>

    <!-- Object list (flat list with virtualization) -->
    <ListBox ItemsSource="{Binding Nodes}"
             SelectedItem="{Binding SelectedNode}"
             Background="Transparent"
             >
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="models:UObjectNode">
          <StackPanel Orientation="Horizontal" Spacing="6" Margin="2">
            <TextBlock Text="{Binding ClassName}"
                       Foreground="#569CD6" FontSize="12"
                       MinWidth="120"/>
            <TextBlock Text="{Binding Name}"
                       Foreground="#D4D4D4" FontSize="12"/>
            <TextBlock Text="{Binding Address}"
                       Foreground="#6A9955" FontSize="11"
                       Opacity="0.7"/>
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</UserControl>
